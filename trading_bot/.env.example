# Copy this file to .env and fill in your Binance Futures Testnet keys,
# then `export $(cat .env | xargs)` before running the CLI (or use
# python-dotenv / your shell's preferred method of loading env files).
#
# Generate keys at: https://testnet.binancefuture.com  (log in -> API Key)

BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here
